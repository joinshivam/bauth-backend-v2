<!DOCTYPE html>
<html>
<head>
  <title>Create Service</title>
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body>
  <div class="shell">
    <aside class="sidebar">
      <div class="brand">
        <span class="brand-mark">B</span>
        <div>
          <strong>BAuth IDP</strong>
          <small>Admin control center</small>
        </div>
      </div>
      <nav>
        <a href="/admin">Dashboard</a>
        <a href="/admin/services">Services</a>
        <a class="active" href="/admin/services/create">Add service</a>
        <a href="/admin/cors">CORS origins</a>
      </nav>
    </aside>

    <main class="content narrow">
      <div class="page-head">
        <div>
          <p class="eyebrow">Register a relying service</p>
          <h1>Create service</h1>
          <p class="muted">The callback URI must exactly match the service callback used during SSO.</p>
        </div>
      </div>

      <section class="panel">
        <form method="POST" class="form-grid">
          <label>
            Service name
            <input type="text" name="name" placeholder="BMailer" required>
          </label>

          <label>
            Service type
            <select name="client_type" required>
              <option value="first_party">First-party BAuth service</option>
              <option value="third_party">Third-party service</option>
            </select>
          </label>

          <label>
            Frontend URL
            <input type="url" name="client_uri" placeholder="https://service.example.com" required>
          </label>

          <label>
            Backend URL
            <input type="url" name="backend_uri" placeholder="https://api.service.example.com" required>
          </label>

          <label>
            Callback URL
            <input type="url" name="callback_uri" placeholder="https://service.example.com/auth/callback" required>
          </label>

          <div class="form-actions">
            <a class="btn ghost" href="/admin/services">Cancel</a>
            <button type="submit">Create service</button>
          </div>
        </form>
      </section>
    </main>
  </div>
</body>
</html>
